{
  "name": "userscripts",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalogs": {
      "cli": {
        "rolldown": "^1.0.1",
        "zod": "^4.4.3"
      },
      "dev": {
        "tsdown": "0.22.0",
        "wrangler": "4.92.0"
      },
      "registry": {
        "@astrojs/cloudflare": "13.5.1",
        "@astrojs/solid-js": "6.0.1",
        "@tailwindcss/vite": "4.3.0",
        "astro": "6.3.3",
        "solid-js": "1.9.13",
        "tailwindcss": "4.3.0"
      }
    }
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome check --write --linter-enabled=false",
    "build:app": "bun run --cwd ./apps/registry build",
    "build:cli": "bun run --cwd ./packages/usts build",
    "build": "bun run build:cli",
    "test": "bun run --cwd ./packages/usts test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@gameroman/config": "0.1.0"
  },
  "overrides": {
    "@babel/generator": "8.0.0-rc.5",
    "@babel/parser": "8.0.0-rc.5",
    "@babel/core": "8.0.0-rc.5",
    "@babel/types": "8.0.0-rc.5",
    "@babel/traverse": "8.0.0-rc.5",
    "@babel/helper-validator-identifier": "8.0.0-rc.5",
    "esbuild": "0.28.0",
    "get-tsconfig": "5.0.0-beta.5",
    "is-docker": "4.0.0",
    "unstorage": "2.0.0-alpha.7"
  }
}
