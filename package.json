{
  "name": "userscripts",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@astrojs/cloudflare": "^13.1.3",
      "@astrojs/solid-js": "^6.0.1",
      "@tailwindcss/vite": "^4.2.2",
      "astro": "^6.0.8",
      "drizzle-orm": "^0.45.1",
      "rolldown": "^1.0.0-rc.9",
      "solid-js": "^1.9.11",
      "tailwindcss": "^4.2.2",
      "tsdown": "^0.21.4",
      "wrangler": "^4.76.0",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome check --write --linter-enabled=false",
    "build:app": "bun run --cwd ./apps/registry build",
    "build:cli": "bun run --cwd ./packages/usts build",
    "build": "bun run build:cli",
    "test": "bun run --cwd ./packages/usts test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@gameroman/config": "^0.0.2"
  },
  "overrides": {
    "esbuild": "^0.27.3",
    "@babel/generator": "8.0.0-rc.3",
    "@babel/parser": "8.0.0-rc.3",
    "@babel/core": "8.0.0-rc.3",
    "@babel/types": "8.0.0-rc.3",
    "@babel/traverse": "8.0.0-rc.3",
    "@babel/helper-validator-identifier": "8.0.0-rc.3",
    "unstorage": "alpha"
  }
}
